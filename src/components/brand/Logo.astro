---
interface Props {
  size?: "sm" | "md" | "lg";
  variant?: "full" | "icon";
  class?: string;
}

const { size = "md", variant = "full", class: className = "" } = Astro.props;

const dimensions = {
  sm: { icon: { w: 32, h: 32 }, full: { w: 160, h: 32 } },
  md: { icon: { w: 48, h: 48 }, full: { w: 240, h: 48 } },
  lg: { icon: { w: 64, h: 64 }, full: { w: 320, h: 64 } },
};

const dim = dimensions[size][variant];
---

{variant === "full" ? (
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 320 64"
    width={dim.w}
    height={dim.h}
    class:list={["logo", className]}
    aria-label="Agra Tour Guides"
    role="img"
  >
    <defs>
      <linearGradient id="logo-gold-gradient" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="#FBBF24" />
        <stop offset="50%" stop-color="#D97706" />
        <stop offset="100%" stop-color="#B45309" />
      </linearGradient>
      <linearGradient id="logo-gold-shine" x1="0" y1="0" x2="1" y2="1">
        <stop offset="0%" stop-color="#FDE68A" />
        <stop offset="40%" stop-color="#F59E0B" />
        <stop offset="100%" stop-color="#92400E" />
      </linearGradient>
    </defs>

    <!-- Taj Mahal dome icon -->
    <g transform="translate(4, 4)">
      <!-- Main dome -->
      <path
        d="M28 12 C28 12, 20 12, 14 24 C10 31, 8 38, 8 42 L48 42 C48 38, 46 31, 42 24 C36 12, 28 12, 28 12 Z"
        fill="url(#logo-gold-gradient)"
      />
      <!-- Dome finial (spire) -->
      <path
        d="M28 4 L28 12 M26 6 C26 4, 28 2, 28 2 C28 2, 30 4, 30 6"
        stroke="url(#logo-gold-gradient)"
        stroke-width="2"
        stroke-linecap="round"
        fill="none"
      />
      <!-- Dome highlight arc -->
      <path
        d="M22 20 C24 16, 32 16, 34 20"
        stroke="#FDE68A"
        stroke-width="1"
        stroke-linecap="round"
        fill="none"
        opacity="0.6"
      />
      <!-- Base platform -->
      <rect x="4" y="42" width="48" height="4" rx="1" fill="url(#logo-gold-gradient)" />
      <!-- Minarets -->
      <rect x="6" y="28" width="3" height="14" rx="1" fill="url(#logo-gold-gradient)" opacity="0.7" />
      <rect x="47" y="28" width="3" height="14" rx="1" fill="url(#logo-gold-gradient)" opacity="0.7" />
      <!-- Minaret caps -->
      <ellipse cx="7.5" cy="27" rx="2.5" ry="2" fill="url(#logo-gold-gradient)" opacity="0.7" />
      <ellipse cx="48.5" cy="27" rx="2.5" ry="2" fill="url(#logo-gold-gradient)" opacity="0.7" />
      <!-- Arch doorway -->
      <path
        d="M23 42 L23 34 C23 30, 28 28, 33 34 L33 42"
        fill="#92400E"
        opacity="0.4"
      />
    </g>

    <!-- Text: "Agra Tour Guides" -->
    <text
      x="72"
      y="30"
      font-family="'Playfair Display Variable', 'Playfair Display', Georgia, serif"
      font-weight="700"
      font-size="22"
      fill="url(#logo-gold-shine)"
      letter-spacing="0.5"
    >Agra Tour Guides</text>

    <!-- Tagline -->
    <text
      x="72"
      y="48"
      font-family="'Inter Variable', 'Inter', system-ui, sans-serif"
      font-weight="400"
      font-size="10"
      fill="currentColor"
      opacity="0.8"
      letter-spacing="2"
    >HERITAGE &bull; CULTURE &bull; EXPERIENCE</text>
  </svg>
) : (
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 56 56"
    width={dim.w}
    height={dim.h}
    class:list={["logo", className]}
    aria-label="Agra Tour Guides"
    role="img"
  >
    <defs>
      <linearGradient id="icon-gold-gradient" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="#FBBF24" />
        <stop offset="50%" stop-color="#D97706" />
        <stop offset="100%" stop-color="#B45309" />
      </linearGradient>
    </defs>

    <!-- Main dome -->
    <path
      d="M28 12 C28 12, 20 12, 14 24 C10 31, 8 38, 8 42 L48 42 C48 38, 46 31, 42 24 C36 12, 28 12, 28 12 Z"
      fill="url(#icon-gold-gradient)"
    />
    <!-- Dome finial (spire) -->
    <path
      d="M28 4 L28 12 M26 6 C26 4, 28 2, 28 2 C28 2, 30 4, 30 6"
      stroke="url(#icon-gold-gradient)"
      stroke-width="2"
      stroke-linecap="round"
      fill="none"
    />
    <!-- Dome highlight arc -->
    <path
      d="M22 20 C24 16, 32 16, 34 20"
      stroke="#FDE68A"
      stroke-width="1"
      stroke-linecap="round"
      fill="none"
      opacity="0.6"
    />
    <!-- Base platform -->
    <rect x="4" y="42" width="48" height="4" rx="1" fill="url(#icon-gold-gradient)" />
    <!-- Minarets -->
    <rect x="6" y="28" width="3" height="14" rx="1" fill="url(#icon-gold-gradient)" opacity="0.7" />
    <rect x="47" y="28" width="3" height="14" rx="1" fill="url(#icon-gold-gradient)" opacity="0.7" />
    <!-- Minaret caps -->
    <ellipse cx="7.5" cy="27" rx="2.5" ry="2" fill="url(#icon-gold-gradient)" opacity="0.7" />
    <ellipse cx="48.5" cy="27" rx="2.5" ry="2" fill="url(#icon-gold-gradient)" opacity="0.7" />
    <!-- Arch doorway -->
    <path
      d="M23 42 L23 34 C23 30, 28 28, 33 34 L33 42"
      fill="#92400E"
      opacity="0.4"
    />
  </svg>
)}
