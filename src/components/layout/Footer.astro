---
import Logo from "../brand/Logo.astro";
import {
  CONTACT_PHONE,
  CONTACT_EMAIL,
  WHATSAPP_NUMBER_DIGITS,
  REVIEW_COUNT,
  REVIEW_RATING,
} from "../../lib/constants";

const currentYear = new Date().getFullYear();
const phoneTel = CONTACT_PHONE.replace(/[^0-9+]/g, "");

const destinations = [
  { label: "Agra", href: "/agra" },
  { label: "Delhi", href: "/delhi" },
  { label: "Jaipur", href: "/jaipur" },
  { label: "Taj Mahal", href: "/agra/taj-mahal" },
  { label: "Amber Fort", href: "/jaipur/amber-fort" },
  { label: "Red Fort", href: "/delhi/red-fort" },
  { label: "Qutub Minar", href: "/delhi/qutub-minar" },
  { label: "Hawa Mahal", href: "/jaipur/hawa-mahal" },
];

const quickLinks = [
  { label: "Tours", href: "/tours" },
  { label: "Services", href: "/services" },
  { label: "Reviews", href: "/reviews" },
  { label: "Travel Guides", href: "/guides" },
  { label: "About Us", href: "/about" },
  { label: "Contact", href: "/contact" },
  { label: "FAQ", href: "/faq" },
  { label: "Privacy Policy", href: "/privacy" },
  { label: "Terms", href: "/terms" },
];
---

<!-- Start Your Journey CTA -->
<div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
  <div class="relative -mb-20 rounded-2xl bg-gradient-to-r from-amber-600 to-orange-500 px-6 py-10 sm:px-12 sm:py-14 overflow-hidden">
    <!-- Decorative pattern -->
    <div class="absolute inset-0 opacity-10">
      <svg class="h-full w-full" viewBox="0 0 400 200" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="50" cy="50" r="80" stroke="white" stroke-width="1" />
        <circle cx="350" cy="150" r="120" stroke="white" stroke-width="1" />
        <circle cx="200" cy="100" r="60" stroke="white" stroke-width="0.5" />
      </svg>
    </div>
    <div class="relative flex flex-col items-center gap-6 text-center lg:flex-row lg:justify-between lg:text-left">
      <div>
        <h3 class="text-2xl font-bold text-white sm:text-3xl">Start Your Journey Today</h3>
        <p class="mt-2 text-lg text-white/90">
          Experience India's Golden Triangle with expert local guides.
        </p>
      </div>
      <div class="flex flex-col items-center gap-4 sm:flex-row">
        <a
          href="/contact"
          class="inline-flex items-center rounded-full bg-white px-8 py-3.5 text-sm font-bold text-amber-700 shadow-lg transition-all hover:bg-gray-50 hover:shadow-xl"
        >
          Book a Tour
        </a>
        <a
          href={`https://wa.me/${WHATSAPP_NUMBER_DIGITS}?text=Hi! I would like to book a tour with Agra Tour Guides.`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-lg font-semibold text-white hover:text-white/80 transition-colors"
        >
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347" />
          </svg>
          WhatsApp Us
        </a>
      </div>
    </div>
  </div>
</div>

<!-- Main Footer -->
<footer class="bg-gray-950 pt-32 md:pt-36 pb-0">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">
      <!-- Column 1: Brand -->
      <div class="md:col-span-2 lg:col-span-1">
        <a href="/" class="inline-block">
          <Logo variant="full" size="md" />
        </a>
        <p class="mt-4 text-sm leading-relaxed text-gray-400">
          A government-licensed Agra-based travel agency. {REVIEW_RATING.toFixed(1)}★ Google rating from {REVIEW_COUNT}+ verified travellers across 30+ countries. Private Taj Mahal tours, Agra Fort, and Golden Triangle itineraries in English, Hindi & Japanese.
        </p>
        <!-- Social Icons -->
        <div class="mt-6 flex gap-3">
          <!-- Facebook -->
          <a
            href="#"
            aria-label="Facebook"
            class="flex w-10 h-10 items-center justify-center rounded-full bg-white/10 hover:bg-amber-500 text-gray-400 hover:text-white transition-colors"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" />
            </svg>
          </a>
          <!-- Instagram -->
          <a
            href="#"
            aria-label="Instagram"
            class="flex w-10 h-10 items-center justify-center rounded-full bg-white/10 hover:bg-amber-500 text-gray-400 hover:text-white transition-colors"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 1.17.054 1.97.24 2.43.403a4.088 4.088 0 011.523.992 4.088 4.088 0 01.992 1.523c.163.46.349 1.26.403 2.43.058 1.266.07 1.646.07 4.85s-.012 3.584-.07 4.85c-.054 1.17-.24 1.97-.403 2.43a4.088 4.088 0 01-.992 1.523 4.088 4.088 0 01-1.523.992c-.46.163-1.26.349-2.43.403-1.266.058-1.646.07-4.85.07s-3.584-.012-4.85-.07c-1.17-.054-1.97-.24-2.43-.403a4.088 4.088 0 01-1.523-.992 4.088 4.088 0 01-.992-1.523c-.163-.46-.349-1.26-.403-2.43C2.175 15.584 2.163 15.204 2.163 12s.012-3.584.07-4.85c.054-1.17.24-1.97.403-2.43a4.088 4.088 0 01.992-1.523A4.088 4.088 0 015.15 2.636c.46-.163 1.26-.349 2.43-.403C8.846 2.175 9.226 2.163 12 2.163zm0 1.802c-3.153 0-3.506.012-4.747.068-1.146.053-1.769.244-2.183.405a3.61 3.61 0 00-1.344.874 3.61 3.61 0 00-.874 1.344c-.161.414-.352 1.037-.405 2.183-.056 1.241-.068 1.594-.068 4.747s.012 3.506.068 4.747c.053 1.146.244 1.769.405 2.183a3.61 3.61 0 00.874 1.344 3.61 3.61 0 001.344.874c.414.161 1.037.352 2.183.405 1.241.056 1.594.068 4.747.068s3.506-.012 4.747-.068c1.146-.053 1.769-.244 2.183-.405a3.61 3.61 0 001.344-.874 3.61 3.61 0 00.874-1.344c.161-.414.352-1.037.405-2.183.056-1.241.068-1.594.068-4.747s-.012-3.506-.068-4.747c-.053-1.146-.244-1.769-.405-2.183a3.61 3.61 0 00-.874-1.344 3.61 3.61 0 00-1.344-.874c-.414-.161-1.037-.352-2.183-.405-1.241-.056-1.594-.068-4.747-.068zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z" />
            </svg>
          </a>
          <!-- YouTube -->
          <a
            href="#"
            aria-label="YouTube"
            class="flex w-10 h-10 items-center justify-center rounded-full bg-white/10 hover:bg-amber-500 text-gray-400 hover:text-white transition-colors"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z" />
            </svg>
          </a>
          <!-- X (Twitter) -->
          <a
            href="#"
            aria-label="X"
            class="flex w-10 h-10 items-center justify-center rounded-full bg-white/10 hover:bg-amber-500 text-gray-400 hover:text-white transition-colors"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
            </svg>
          </a>
          <!-- WhatsApp -->
          <a
            href="https://wa.me/919999999999"
            aria-label="WhatsApp"
            class="flex w-10 h-10 items-center justify-center rounded-full bg-white/10 hover:bg-emerald-500 text-gray-400 hover:text-white transition-colors"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Column 2: Destinations -->
      <div>
        <h3 class="text-amber-400 text-xs font-semibold uppercase tracking-widest mb-6">
          Destinations
        </h3>
        <ul class="space-y-2.5">
          {
            destinations.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-gray-400 hover:text-white transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Column 3: Quick Links -->
      <div>
        <h3 class="text-amber-400 text-xs font-semibold uppercase tracking-widest mb-6">
          Quick Links
        </h3>
        <ul class="space-y-2.5">
          {
            quickLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-gray-400 hover:text-white transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Column 4: Contact -->
      <div>
        <h3 class="text-amber-400 text-xs font-semibold uppercase tracking-widest mb-6">
          Get in Touch
        </h3>
        <ul class="space-y-4">
          <!-- Address -->
          <li class="flex items-start gap-3">
            <svg class="mt-0.5 h-5 w-5 shrink-0 text-gray-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
            </svg>
            <span class="text-sm text-gray-400">
              Near East Gate, Taj Mahal,<br />Agra, Uttar Pradesh 282001, India
            </span>
          </li>
          <!-- Phone -->
          <li>
            <a href={`tel:${phoneTel}`} class="flex items-center gap-3 text-sm text-gray-400 hover:text-white transition-colors">
              <svg class="h-5 w-5 shrink-0 text-gray-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
              </svg>
              {CONTACT_PHONE}
            </a>
          </li>
          <!-- Email -->
          <li>
            <a href={`mailto:${CONTACT_EMAIL}`} class="flex items-center gap-3 text-sm text-gray-400 hover:text-white transition-colors">
              <svg class="h-5 w-5 shrink-0 text-gray-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
              </svg>
              {CONTACT_EMAIL}
            </a>
          </li>
          <!-- WhatsApp -->
          <li>
            <a href="https://wa.me/919999999999" class="flex items-center gap-3 text-sm text-gray-400 hover:text-emerald-400 transition-colors">
              <svg class="h-5 w-5 shrink-0 text-emerald-500" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
              </svg>
              WhatsApp Us
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="mt-12 border-t border-white/10">
    <div class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
      <div class="flex flex-col items-center justify-between gap-4 sm:flex-row">
        <p class="text-gray-500 text-sm">
          &copy; {currentYear} Agra Tour Guides. All rights reserved.
        </p>
        <div class="flex items-center gap-6">
          <span class="text-xs text-gray-600 tracking-wide">{REVIEW_RATING.toFixed(1)}★ Google · {REVIEW_COUNT}+ verified reviews</span>
          <span class="text-gray-700">|</span>
          <span class="text-xs text-gray-600 tracking-wide">Ministry of Tourism Licensed</span>
        </div>
      </div>
    </div>
  </div>
</footer>
