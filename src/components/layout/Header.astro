---
import Logo from "../brand/Logo.astro";

interface Props {
  /**
   * When true, header starts transparent (white text) and animates into a
   * solid white bar on scroll — for pages with a dark cinematic hero.
   * When false (default), header is always solid white with dark text —
   * for inner pages where the content immediately after sits on a light bg.
   */
  transparent?: boolean;
}

interface NavItem {
  label: string;
  href: string;
}

const { transparent = false } = Astro.props;

const navItems: NavItem[] = [
  { label: "Tours", href: "/tours" },
  { label: "Services", href: "/services" },
  { label: "Agra", href: "/agra" },
  { label: "Delhi", href: "/delhi" },
  { label: "Jaipur", href: "/jaipur" },
  { label: "Reviews", href: "/reviews" },
  { label: "Guides", href: "/guides" },
  { label: "Contact", href: "/contact" },
];

const currentPath = Astro.url.pathname;

// Always-solid header for inner pages: skip the transparent → scrolled animation
// and just use white bg + dark text from page load.
const headerClass = transparent
  ? "fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-transparent data-[scrolled]:bg-white/90 data-[scrolled]:backdrop-blur-xl data-[scrolled]:shadow-sm"
  : "fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-xl shadow-sm border-b border-gray-100";

const navLinkClass = transparent
  ? "text-white data-[header-scrolled]:text-gray-700"
  : "text-gray-700 hover:text-amber-700";

const logoTextClass = transparent ? "text-white" : "text-gray-900";

const hamburgerLineClass = transparent
  ? "bg-white data-[header-scrolled]:bg-gray-800"
  : "bg-gray-800";
---

<header
  class={headerClass}
  data-transparent={transparent ? "" : null}
  id="site-header"
>
  <nav class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between lg:h-20">
      <!-- Logo -->
      <a href="/" class:list={["flex items-center gap-2 shrink-0", logoTextClass]} data-logo-link>
        <Logo size="sm" />
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden items-center gap-1 lg:flex">
        {
          navItems.map((item) => {
            const isActive = currentPath === item.href || (item.href !== "/" && currentPath.startsWith(item.href));
            return (
              <a
                href={item.href}
                class:list={[
                  "relative px-3 py-2 text-sm font-medium tracking-wide transition-colors duration-300",
                  navLinkClass,
                  "group",
                  isActive && "nav-active",
                ]}
                data-nav-link
              >
                {item.label}
                <span
                  class:list={[
                    "absolute bottom-0 left-3 right-3 h-0.5 bg-amber-500 transition-transform duration-300 origin-left",
                    isActive ? "scale-x-100" : "scale-x-0 group-hover:scale-x-100",
                  ]}
                />
              </a>
            );
          })
        }
        <a
          href="/contact"
          class="ml-4 bg-amber-500 hover:bg-amber-600 text-white px-6 py-2.5 rounded-full text-sm font-semibold transition-all hover:shadow-lg hover:shadow-amber-500/25"
        >
          Book Now
        </a>
      </div>

      <!-- Mobile Hamburger -->
      <button
        type="button"
        class="relative flex items-center justify-center w-10 h-10 lg:hidden"
        aria-label="Open menu"
        id="mobile-menu-btn"
      >
        <div class="flex flex-col items-center justify-center gap-1.5 w-6" id="hamburger-icon">
          <span class:list={["block h-0.5 w-6 transition-all duration-300 origin-center", hamburgerLineClass]} data-hamburger-line="1"></span>
          <span class:list={["block h-0.5 w-6 transition-all duration-300 origin-center", hamburgerLineClass]} data-hamburger-line="2"></span>
          <span class:list={["block h-0.5 w-4 transition-all duration-300 origin-center ml-auto", hamburgerLineClass]} data-hamburger-line="3"></span>
        </div>
      </button>
    </div>
  </nav>
</header>

<!-- Mobile Menu Overlay -->
<div
  class="fixed inset-0 z-[60] bg-gray-950/95 backdrop-blur-2xl opacity-0 pointer-events-none transition-opacity duration-300 data-[menu-open]:opacity-100 data-[menu-open]:pointer-events-auto lg:hidden"
  id="mobile-menu"
>
  <!-- Close Button -->
  <button
    type="button"
    class="absolute top-4 right-4 flex items-center justify-center w-10 h-10 text-white/80 hover:text-white transition-colors"
    aria-label="Close menu"
    id="mobile-menu-close"
  >
    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
    </svg>
  </button>

  <!-- Mobile Nav Links -->
  <div class="flex flex-col items-center justify-center h-full">
    <div class="flex flex-col items-center gap-2">
      {
        navItems.map((item, index) => {
          const isActive = currentPath === item.href || (item.href !== "/" && currentPath.startsWith(item.href));
          return (
            <a
              href={item.href}
              class:list={[
                "text-2xl font-medium tracking-wide transition-all duration-300 py-3 px-6",
                "opacity-0 translate-y-4 data-[menu-open]:opacity-100 data-[menu-open]:translate-y-0",
                isActive ? "text-amber-400" : "text-white/80 hover:text-amber-400",
              ]}
              style={`transition-delay: ${(index + 1) * 75}ms;`}
              data-mobile-link
            >
              {item.label}
            </a>
          );
        })
      }
    </div>

    <div
      class="mt-10 opacity-0 translate-y-4 data-[menu-open]:opacity-100 data-[menu-open]:translate-y-0 transition-all duration-300"
      style={`transition-delay: ${(navItems.length + 1) * 75}ms;`}
      data-mobile-link
    >
      <a
        href="/contact"
        class="bg-amber-500 hover:bg-amber-600 text-white px-10 py-3.5 rounded-full text-lg font-semibold transition-all hover:shadow-lg hover:shadow-amber-500/25"
      >
        Book Now
      </a>
    </div>
  </div>
</div>

<script>
  function initHeader() {
    const header = document.getElementById("site-header");
    const menuBtn = document.getElementById("mobile-menu-btn");
    const mobileMenu = document.getElementById("mobile-menu");
    const closeBtn = document.getElementById("mobile-menu-close");
    const navLinks = document.querySelectorAll("[data-nav-link]");
    const hamburgerLines = document.querySelectorAll("[data-hamburger-line]");
    const mobileLinks = document.querySelectorAll("[data-mobile-link]");
    const logoLink = document.querySelector("[data-logo-link]");

    if (!header || !menuBtn || !mobileMenu || !closeBtn) return;

    // Only run the scroll/transparency animation when header is in transparent
    // mode (over a dark hero). Solid-mode headers stay solid white from load.
    const isTransparent = header.hasAttribute("data-transparent");

    if (isTransparent) {
      let ticking = false;
      const onScroll = () => {
        if (!ticking) {
          requestAnimationFrame(() => {
            const scrolled = window.scrollY > 50;
            if (scrolled) {
              header.setAttribute("data-scrolled", "");
            } else {
              header.removeAttribute("data-scrolled");
            }
            navLinks.forEach((link) => {
              if (scrolled) link.setAttribute("data-header-scrolled", "");
              else link.removeAttribute("data-header-scrolled");
            });
            hamburgerLines.forEach((line) => {
              if (scrolled) line.setAttribute("data-header-scrolled", "");
              else line.removeAttribute("data-header-scrolled");
            });
            if (logoLink) {
              if (scrolled) {
                logoLink.classList.remove("text-white");
                logoLink.classList.add("text-gray-900");
              } else {
                logoLink.classList.remove("text-gray-900");
                logoLink.classList.add("text-white");
              }
            }
            ticking = false;
          });
          ticking = true;
        }
      };
      window.addEventListener("scroll", onScroll, { passive: true });
      onScroll();
    }

    // Mobile menu toggle
    function openMenu() {
      mobileMenu.setAttribute("data-menu-open", "");
      document.body.classList.add("overflow-hidden");
      mobileLinks.forEach((link) => {
        link.setAttribute("data-menu-open", "");
      });
      // Morph hamburger to X
      menuBtn.setAttribute("aria-expanded", "true");
    }

    function closeMenu() {
      mobileMenu.removeAttribute("data-menu-open");
      document.body.classList.remove("overflow-hidden");
      mobileLinks.forEach((link) => {
        link.removeAttribute("data-menu-open");
      });
      menuBtn.setAttribute("aria-expanded", "false");
    }

    menuBtn.addEventListener("click", () => {
      const isOpen = mobileMenu.hasAttribute("data-menu-open");
      if (isOpen) {
        closeMenu();
      } else {
        openMenu();
      }
    });

    closeBtn.addEventListener("click", closeMenu);

    // Close on link click
    mobileMenu.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", closeMenu);
    });

    // Close on Escape key
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && mobileMenu.hasAttribute("data-menu-open")) {
        closeMenu();
      }
    });
  }

  initHeader();
  document.addEventListener("astro:after-swap", initHeader);
</script>
