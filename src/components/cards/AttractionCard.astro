---
interface Props {
  title: string;
  slug: string;
  city: string;
  image: string;
  description: string;
  duration?: string;
  rating?: number;
}

const { title, slug, city, image, description, duration, rating } = Astro.props;

const href = `/${city.toLowerCase()}/${slug}/`;

// Generate filled/empty stars
const fullStars = rating ? Math.floor(rating) : 0;
const hasHalf = rating ? rating % 1 >= 0.5 : false;
const emptyStars = rating ? 5 - fullStars - (hasHalf ? 1 : 0) : 0;
---

<a
  href={href}
  class="group block rounded-2xl overflow-hidden bg-white shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-500 ease-out"
>
  <!-- Image Container -->
  <div class="relative aspect-[4/3] overflow-hidden">
    <img
      src={image}
      alt={title}
      class="h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
      loading="lazy"
      decoding="async"
    />

    <!-- Gradient overlay for badge readability -->
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-transparent to-transparent pointer-events-none" />

    <!-- City Badge — top left, glassmorphism -->
    <span class="absolute left-3 top-3 rounded-full bg-white/90 backdrop-blur-sm px-3 py-1 text-xs font-medium text-gray-800 shadow-sm capitalize">
      {city}
    </span>

    <!-- Duration Badge — top right, dark glass -->
    {duration && (
      <span class="absolute right-3 top-3 rounded-full bg-black/60 backdrop-blur-sm px-3 py-1 text-xs font-medium text-white shadow-sm flex items-center gap-1">
        <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
        </svg>
        {duration}
      </span>
    )}
  </div>

  <!-- Content -->
  <div class="p-5">
    <h3 class="text-lg font-bold text-gray-900 group-hover:text-amber-700 transition-colors duration-300 leading-snug">
      {title}
    </h3>

    <p class="mt-2 text-sm text-gray-600 line-clamp-2 leading-relaxed">
      {description}
    </p>

    <!-- Bottom Row: Rating + Explore Link -->
    <div class="mt-4 flex items-center justify-between">
      <!-- Star Rating -->
      {rating && (
        <div class="flex items-center gap-1.5">
          <div class="flex items-center gap-0.5">
            {Array.from({ length: fullStars }).map(() => (
              <svg class="h-4 w-4 text-amber-400" viewBox="0 0 20 20" fill="currentColor">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
            {hasHalf && (
              <svg class="h-4 w-4 text-amber-400" viewBox="0 0 20 20">
                <defs>
                  <linearGradient id={`half-star-${slug}`}>
                    <stop offset="50%" stop-color="currentColor" />
                    <stop offset="50%" stop-color="#d1d5db" />
                  </linearGradient>
                </defs>
                <path fill={`url(#half-star-${slug})`} d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            )}
            {Array.from({ length: emptyStars }).map(() => (
              <svg class="h-4 w-4 text-gray-300" viewBox="0 0 20 20" fill="currentColor">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <span class="text-xs font-medium text-gray-500">{rating.toFixed(1)}</span>
        </div>
      )}

      <!-- Explore Link -->
      <span class="inline-flex items-center gap-1 text-sm font-semibold text-amber-600 group-hover:text-amber-700 transition-colors duration-300">
        Explore
        <svg class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </span>
    </div>
  </div>
</a>
