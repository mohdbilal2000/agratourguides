---
interface Props {
  title: string;
  slug: string;
  image: string;
  description: string;
  category: string;
  readTime?: string;
}

const { title, slug, image, description, category, readTime } = Astro.props;

const href = `/guides/${slug}`;
---

<a
  href={href}
  class="group flex flex-col md:flex-row rounded-2xl overflow-hidden bg-white shadow-sm hover:shadow-xl transition-all duration-500 ease-out"
>
  <!-- Image Container -->
  <div class="relative md:w-2/5 aspect-video md:aspect-auto overflow-hidden">
    <img
      src={image}
      alt={title}
      class="h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
      loading="lazy"
      decoding="async"
    />

    <!-- Gradient overlay -->
    <div class="absolute inset-0 bg-gradient-to-b md:bg-gradient-to-r from-black/20 via-transparent to-transparent pointer-events-none" />

    <!-- Category Badge overlaid on image -->
    <span class="absolute left-3 top-3 rounded-full bg-white/90 backdrop-blur-sm px-3 py-1 text-xs font-medium text-gray-800 shadow-sm">
      {category}
    </span>
  </div>

  <!-- Content Side -->
  <div class="p-6 flex flex-col justify-center md:w-3/5">
    <!-- Category label -->
    <span class="text-xs font-semibold uppercase tracking-wide text-amber-600">
      {category}
    </span>

    <h3 class="text-xl font-bold text-gray-900 mt-2 group-hover:text-amber-700 transition-colors duration-300 leading-snug">
      {title}
    </h3>

    <p class="mt-3 text-gray-600 line-clamp-3 leading-relaxed text-sm">
      {description}
    </p>

    <!-- Bottom Row: Read time + Read Guide link -->
    <div class="mt-4 flex items-center justify-between">
      {readTime && (
        <span class="flex items-center gap-1.5 text-xs text-gray-400 font-medium">
          <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
          </svg>
          {readTime}
        </span>
      )}

      <span class="inline-flex items-center gap-1 text-sm font-semibold text-amber-600 group-hover:text-amber-700 transition-colors duration-300">
        Read Guide
        <svg class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </span>
    </div>
  </div>
</a>
