---
import { WHATSAPP_NUMBER_DIGITS } from "../../lib/constants";

interface Props {
  title?: string;
  subtitle?: string;
  ctaText?: string;
  ctaLink?: string;
  backgroundImage?: string;
}

const {
  title = "Ready to Explore the Wonders of India?",
  subtitle = "Book your private guided tour today and experience the magic of India's most iconic monuments with a licensed expert by your side.",
  ctaText = "Plan Your Trip",
  ctaLink = "/contact",
  backgroundImage = "https://images.unsplash.com/photo-1548013146-72479768bada?w=1600&q=80",
} = Astro.props;

const waUrl = `https://wa.me/${WHATSAPP_NUMBER_DIGITS}?text=${encodeURIComponent("Hi! I would like to book a tour with Agra Tour Guides.")}`;
---

<section class="py-8 md:py-12">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="relative overflow-hidden rounded-2xl">
      <!-- Background image -->
      <img
        src={backgroundImage}
        alt=""
        role="presentation"
        class="absolute inset-0 h-full w-full object-cover"
        loading="lazy"
        decoding="async"
      />

      <!-- Dark gradient overlay -->
      <div class="absolute inset-0 bg-gradient-to-r from-gray-900/95 via-gray-900/80 to-gray-900/60"></div>

      <!-- Content -->
      <div class="relative py-20 md:py-28 px-8 md:px-16 lg:px-20">
        <div class="max-w-2xl">
          <!-- Gold label -->
          <span class="inline-block text-xs font-bold tracking-[0.2em] uppercase text-amber-400 mb-4">
            Start Your Adventure
          </span>

          <!-- Title -->
          <h2 class="heading-display text-3xl sm:text-4xl lg:text-5xl text-white">
            {title}
          </h2>

          <!-- Subtitle -->
          <p class="mt-5 text-base md:text-lg text-gray-300 leading-relaxed max-w-lg">
            {subtitle}
          </p>

          <!-- Buttons -->
          <div class="mt-10 flex flex-wrap items-center gap-4">
            <!-- Primary CTA -->
            <a
              href={ctaLink}
              class="inline-flex items-center gap-2 bg-amber-500 hover:bg-amber-600 text-white font-semibold px-8 py-3.5 rounded-full shadow-lg transition-all duration-300 hover:-translate-y-0.5 hover:shadow-xl"
            >
              {ctaText}
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </a>

            <!-- Secondary: WhatsApp -->
            <a
              href={waUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 border border-white/30 text-white hover:bg-white/10 px-8 py-3.5 rounded-full font-medium transition-all duration-300"
            >
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347" />
              </svg>
              WhatsApp Us
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
