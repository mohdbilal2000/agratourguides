---
interface Props {
  title?: string;
  subtitle?: string;
  ctaText?: string;
  ctaLink?: string;
  backgroundImage?: string;
}

const {
  title = "Ready to Explore the Wonders of India?",
  subtitle = "Book your private guided tour today and experience the magic of India's most iconic monuments with a licensed expert by your side.",
  ctaText = "Plan Your Trip",
  ctaLink = "/contact",
  backgroundImage = "https://images.unsplash.com/photo-1548013146-72479768bada?w=1600&q=80",
} = Astro.props;
---

<section class="py-8 md:py-12">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="relative overflow-hidden rounded-2xl">
      <!-- Background image -->
      <img
        src={backgroundImage}
        alt=""
        role="presentation"
        class="absolute inset-0 h-full w-full object-cover"
        loading="lazy"
        decoding="async"
      />

      <!-- Dark gradient overlay -->
      <div class="absolute inset-0 bg-gradient-to-r from-gray-900/95 via-gray-900/80 to-gray-900/60"></div>

      <!-- Content -->
      <div class="relative py-20 md:py-28 px-8 md:px-16 lg:px-20">
        <div class="max-w-2xl">
          <!-- Gold label -->
          <span class="inline-block text-xs font-bold tracking-[0.2em] uppercase text-amber-400 mb-4">
            Start Your Adventure
          </span>

          <!-- Title -->
          <h2 class="heading-display text-3xl sm:text-4xl lg:text-5xl text-white">
            {title}
          </h2>

          <!-- Subtitle -->
          <p class="mt-5 text-base md:text-lg text-gray-300 leading-relaxed max-w-lg">
            {subtitle}
          </p>

          <!-- Buttons -->
          <div class="mt-10 flex flex-wrap items-center gap-4">
            <!-- Primary CTA -->
            <a
              href={ctaLink}
              class="inline-flex items-center gap-2 bg-amber-500 hover:bg-amber-600 text-white font-semibold px-8 py-3.5 rounded-full shadow-lg transition-all duration-300 hover:-translate-y-0.5 hover:shadow-xl"
            >
              {ctaText}
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </a>

            <!-- Secondary: Call Us -->
            <a
              href="tel:+919999999999"
              class="inline-flex items-center gap-2 border border-white/30 text-white hover:bg-white/10 px-8 py-3.5 rounded-full font-medium transition-all duration-300"
            >
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
              </svg>
              Call Us
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
