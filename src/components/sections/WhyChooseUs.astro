---
const features = [
  {
    icon: "check",
    title: "Born-and-Raised in Agra",
    description:
      "Our team grew up in the shadow of the Taj. The stories you'll hear aren't in any guidebook \u2014 they came from grandparents who watched the marble being cleaned.",
  },
  {
    icon: "shield",
    title: "Government-Licensed",
    description:
      "Every guide carries a Ministry of Tourism (Government of India) licence and ASI certification \u2014 the only legal way to guide inside the Taj Mahal complex.",
  },
  {
    icon: "star",
    title: "5.0\u2605 on Google (81+ reviews)",
    description:
      "Not a marketing claim \u2014 a verified Google Business rating from real travellers across 30+ countries. Read every single review, unedited, on our reviews page.",
  },
  {
    icon: "value",
    title: "Foreigner-First Pricing",
    description:
      "Clear USD and EUR rates published up-front \u2014 no quote-haggling, no tourist surcharges, no shop-commission detours. What you see is what you pay.",
  },
];
---

<section class="py-20 md:py-28 bg-white">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 items-center">
      <!-- Left: Image -->
      <div class="rounded-3xl overflow-hidden shadow-2xl max-h-[500px]">
        <img
          src="https://images.unsplash.com/photo-1524492412937-b28074a5d7da?w=800&q=80"
          alt="Tourists visiting the Taj Mahal in Agra, India"
          class="w-full h-full object-cover max-h-[500px]"
          loading="lazy"
          decoding="async"
        />
      </div>

      <!-- Right: Content -->
      <div class="lg:pl-4">
        <!-- Label -->
        <span class="inline-block text-xs font-bold tracking-[0.2em] uppercase text-amber-600 mb-4">
          Why Travelers Choose Us
        </span>

        <!-- Heading -->
        <h2 class="font-heading text-3xl font-bold text-sandstone-900 sm:text-4xl lg:text-5xl leading-tight">
          We Make Your India Journey Effortless
        </h2>

        <!-- Accent line -->
        <div class="h-1 w-16 bg-gold-400 rounded-full mt-6 mb-10"></div>

        <!-- Feature list -->
        <div class="space-y-8">
          {
            features.map((feature) => (
              <div class="flex gap-4 items-start">
                <!-- Icon circle -->
                <div class="flex-shrink-0 w-12 h-12 rounded-full bg-amber-100 flex items-center justify-center border border-amber-200">
                  {feature.icon === "check" && (
                    <svg class="h-6 w-6 text-amber-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                    </svg>
                  )}
                  {feature.icon === "shield" && (
                    <svg class="h-6 w-6 text-amber-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
                    </svg>
                  )}
                  {feature.icon === "star" && (
                    <svg class="h-6 w-6 text-amber-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" />
                    </svg>
                  )}
                  {feature.icon === "value" && (
                    <svg class="h-6 w-6 text-amber-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                  )}
                </div>

                <!-- Text -->
                <div>
                  <h3 class="text-base font-semibold text-gray-900">
                    {feature.title}
                  </h3>
                  <p class="mt-1 text-sm text-sandstone-600 leading-relaxed">
                    {feature.description}
                  </p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
