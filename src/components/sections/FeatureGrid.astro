---
const services = [
  {
    title: "Licensed Tour Guides",
    description:
      "Government-certified guides fluent in 10+ languages for authentic cultural experiences",
    icon: "guide",
  },
  {
    title: "Custom Tour Packages",
    description:
      "Flexible itineraries tailored to your interests, pace, and budget",
    icon: "map",
  },
  {
    title: "Private Transfers",
    description:
      "Air-conditioned vehicles with professional drivers for comfortable city-to-city travel",
    icon: "car",
  },
  {
    title: "Photography Tours",
    description:
      "Capture stunning shots with guides who know the best angles and golden-hour timing",
    icon: "camera",
  },
];
---

<section class="py-20 md:py-28 bg-white">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="text-center mb-16">
      <div class="flex items-center justify-center gap-4 mb-4">
        <span class="block h-px w-12 bg-gold-400"></span>
        <span class="text-sm font-semibold tracking-widest uppercase text-gold-600">What We Offer</span>
        <span class="block h-px w-12 bg-gold-400"></span>
      </div>
      <h2 class="font-heading text-3xl font-bold text-sandstone-900 sm:text-4xl lg:text-5xl">
        Our Services
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-sandstone-600">
        Everything you need for an unforgettable journey through India's Golden Triangle
      </p>
    </div>

    <!-- Services grid -->
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        services.map((service) => (
          <div class="group bg-white border border-sandstone-100 rounded-2xl p-8 text-center hover:border-gold-200 hover:shadow-lg transition-all duration-500">
            <!-- Icon container -->
            <div class="w-16 h-16 mx-auto rounded-2xl bg-gold-50 flex items-center justify-center mb-6 group-hover:bg-gold-500 transition-colors duration-500">
              {service.icon === "guide" && (
                <svg class="h-7 w-7 text-gold-600 group-hover:text-white transition-colors duration-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 12l2.25 2.25L21 12" />
                </svg>
              )}
              {service.icon === "map" && (
                <svg class="h-7 w-7 text-gold-600 group-hover:text-white transition-colors duration-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498l4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 00-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0z" />
                </svg>
              )}
              {service.icon === "car" && (
                <svg class="h-7 w-7 text-gold-600 group-hover:text-white transition-colors duration-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12" />
                </svg>
              )}
              {service.icon === "camera" && (
                <svg class="h-7 w-7 text-gold-600 group-hover:text-white transition-colors duration-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6.827 6.175A2.31 2.31 0 015.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 00-1.134-.175 2.31 2.31 0 01-1.64-1.055l-.822-1.316a2.192 2.192 0 00-1.736-1.039 48.774 48.774 0 00-5.232 0 2.192 2.192 0 00-1.736 1.039l-.821 1.316z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 12.75a4.5 4.5 0 11-9 0 4.5 4.5 0 019 0z" />
                </svg>
              )}
            </div>

            <!-- Title -->
            <h3 class="text-lg font-bold text-sandstone-900 mt-4 font-heading">
              {service.title}
            </h3>

            <!-- Description -->
            <p class="text-sm text-sandstone-600 mt-2 leading-relaxed">
              {service.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
