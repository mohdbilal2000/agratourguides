---
import PageLayout from '../layouts/PageLayout.astro';
import Container from '../components/ui/Container.astro';
import Section from '../components/ui/Section.astro';
import Breadcrumbs from '../components/layout/Breadcrumbs.astro';
import { buildOrganizationSchema, buildBreadcrumbSchema } from '../lib/schema';
import { SITE_NAME, SITE_URL, CONTACT_EMAIL } from '../lib/constants';

const pageUrl = `${SITE_URL}/privacy/`;
const lastUpdated = "April 29, 2026";

const jsonLd = [
  buildOrganizationSchema(),
  buildBreadcrumbSchema([
    { name: 'Home', url: SITE_URL },
    { name: 'Privacy Policy', url: pageUrl },
  ]),
];

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Privacy Policy' },
];
---

<PageLayout
  title={`Privacy Policy — ${SITE_NAME}`}
  description={`How ${SITE_NAME} handles personal data: contact details, booking information, cookies, and your rights as a traveller.`}
  jsonLd={jsonLd}
  noindex={false}
>
  <Section class="bg-white">
    <Container>
      <Breadcrumbs items={breadcrumbs} />
      <article class="prose prose-stone max-w-3xl mx-auto mt-6">
        <h1 class="font-heading text-3xl md:text-4xl font-bold text-gray-900">Privacy Policy</h1>
        <p class="text-sm text-gray-500">Last updated: {lastUpdated}</p>

        <p>{SITE_NAME} ("we", "us", "our") is a government-licensed tour agency based in Agra, India. This page explains what personal data we collect when you contact us, how we use it, and your rights.</p>

        <h2>What we collect</h2>
        <ul>
          <li><strong>Contact details</strong> you give us via WhatsApp, email or our booking form: name, country, phone number, email, travel dates, group size, language preference.</li>
          <li><strong>Payment information</strong> if you transfer an advance: only enough to confirm receipt. We do not store full card numbers.</li>
          <li><strong>Site analytics</strong>: anonymised page-view data via privacy-friendly analytics. No personal advertising profiles.</li>
        </ul>

        <h2>How we use it</h2>
        <ul>
          <li>To prepare your tour quote and confirm bookings.</li>
          <li>To coordinate with the licensed guide, driver or partner hotel assigned to you.</li>
          <li>To send post-tour follow-up — once — asking for an honest Google review. You can opt out at any time.</li>
          <li>To comply with Indian tax and tourism record-keeping requirements.</li>
        </ul>

        <h2>Who we share it with</h2>
        <p>Only the people we need to deliver your booking: the guide assigned to your tour, the driver, the hotel (if booked through us), and our accountant for tax records. Never sold, never shared with advertisers.</p>

        <h2>Cookies</h2>
        <p>We use minimal first-party cookies for site preferences (e.g. language) and aggregate analytics. We do not run ad-tracking pixels. You can clear them any time in your browser.</p>

        <h2>Your rights</h2>
        <ul>
          <li>Ask what we have on you — email <a href={`mailto:${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a>.</li>
          <li>Ask us to delete your data once your tour is complete and tax records are settled.</li>
          <li>Withdraw consent for follow-up messages at any time.</li>
          <li>If you're an EU/UK resident, your GDPR/UK-DPA rights apply.</li>
        </ul>

        <h2>Contact</h2>
        <p>For privacy questions: <a href={`mailto:${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a>. We answer within 5 working days.</p>
      </article>
    </Container>
  </Section>
</PageLayout>
