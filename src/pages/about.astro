---
import PageLayout from '../layouts/PageLayout.astro';
import Container from '../components/ui/Container.astro';
import Section from '../components/ui/Section.astro';
import HeroSection from '../components/sections/HeroSection.astro';
import CTABanner from '../components/sections/CTABanner.astro';
import TrustBadges from '../components/sections/TrustBadges.astro';
import { buildOrganizationSchema } from '../lib/schema';
import { SITE_NAME } from '../lib/constants';

const jsonLd = [buildOrganizationSchema()];
---

<PageLayout
  title={`About Us — ${SITE_NAME}`}
  description="Meet the team behind Agra Tour Guides. Licensed, multilingual tour guides with decades of experience in Agra, Delhi, and Jaipur's Golden Triangle."
  jsonLd={jsonLd}
  transparentHeader
>
  <HeroSection
    title="About Agra Tour Guides"
    subtitle="Licensed, passionate local guides dedicated to sharing the real stories behind India's greatest monuments."
    backgroundImage="https://images.unsplash.com/photo-1524492412937-b28074a5d7da?w=1920&q=80"
  />

  <Section class="bg-white">
    <Container>
      <div class="max-w-3xl mx-auto prose prose-lg prose-stone max-w-none">
        <h2 class="font-heading">Who we are</h2>
        <p>
          Agra Tour Guides is a small, government-licensed travel agency based in Tajganj, the neighbourhood that wakes up every morning to the silhouette of the Taj Mahal. Our team is led by Pawan Agarwal — a Ministry of Tourism-licensed guide with a 5.0★ Google rating from 81+ travellers across 30+ countries — and supported by a tight network of fellow ASI-badged guides, English-speaking drivers, and partner hotels we personally trust.
        </p>
        <p>
          We are not an aggregator. We don't resell tours from other agencies, we don't take shop commissions, and we don't pad quotes with hidden surcharges. What you see on our pricing page is what you pay.
        </p>

        <h2 class="font-heading">Why travellers from 30+ countries pick us</h2>
        <ul>
          <li><strong>Licensed and accountable</strong> — every in-house guide carries a Ministry of Tourism licence and an ASI badge (the only legal credential to enter the Taj Mahal complex with you).</li>
          <li><strong>Languages we speak in-house</strong> — English, Hindi, Japanese. French, Spanish, German, Italian, Russian, Arabic, Mandarin and Korean coordinated with vetted partners on request.</li>
          <li><strong>Real reviews, no curation</strong> — every Google review is on our <a href="/reviews/">reviews page</a>, unedited.</li>
          <li><strong>Foreigner-first transparent pricing</strong> in USD, EUR and INR — no quote-haggling, no commission detours.</li>
          <li><strong>Owner-led communication</strong> — when you message us, you're not in a call-centre queue.</li>
        </ul>

        <h2 class="font-heading">Our promise</h2>
        <p>
          We sell time and stories — not tickets. Our job is to compress decades of Mughal, Rajput and Sufi history into the few hours you have at a monument, and to make sure you leave with photos you'll show people for years. If we can't deliver that on a given day, we'll tell you up-front.
        </p>

        <h2 class="font-heading">What we offer</h2>
        <ul>
          <li><strong>Guide-Only tours</strong> — from $22 for the Taj Mahal, group up to 5.</li>
          <li><strong>Guide + AC Cab</strong> — same-day Agra from Delhi, from $89 per person.</li>
          <li><strong>Golden Triangle all-inclusive</strong> — Delhi → Agra → Jaipur, 3 to 7 days, from $299.</li>
          <li><strong>Custom itineraries</strong> — Rajasthan, Varanasi, Khajuraho, Himalayas, photography-focused, family-friendly.</li>
          <li><strong>Add-ons</strong> — sunrise photography, marble-inlay workshop, food tours, heritage hotels.</li>
        </ul>

        <p class="text-sm text-gray-500 italic">Page last updated April 2026.</p>
      </div>
    </Container>
  </Section>

  <TrustBadges />

  <CTABanner
    title="Ready to explore with a local expert?"
    subtitle="WhatsApp us your dates and we'll send a quote within 2 hours. No deposit required for day tours."
    ctaText="Contact Us"
    ctaLink="/contact/"
  />
</PageLayout>
