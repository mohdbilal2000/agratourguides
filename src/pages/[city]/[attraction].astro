---
import PageLayout from '../../layouts/PageLayout.astro';
import Container from '../../components/ui/Container.astro';
import Section from '../../components/ui/Section.astro';
import HeroSection from '../../components/sections/HeroSection.astro';
import CTABanner from '../../components/sections/CTABanner.astro';
import Breadcrumbs from '../../components/layout/Breadcrumbs.astro';
import Badge from '../../components/ui/Badge.astro';
import AttractionCard from '../../components/cards/AttractionCard.astro';
import TourCard from '../../components/cards/TourCard.astro';
import FAQAccordion from '../../components/react/FAQAccordion';
import PhotoGallery from '../../components/react/PhotoGallery';
import InteractiveMap from '../../components/react/InteractiveMap';
import { getCollection, render } from 'astro:content';
import { buildTouristAttractionSchema, buildFAQSchema, buildBreadcrumbSchema } from '../../lib/schema';
import { SITE_NAME, SITE_URL } from '../../lib/constants';

export async function getStaticPaths() {
  const attractions = await getCollection('attractions');
  return attractions.map((attraction) => ({
    params: { city: attraction.data.city, attraction: attraction.data.slug },
    props: { attraction },
  }));
}

const { attraction } = Astro.props;
const { Content } = await render(attraction);

const attractionImages: Record<string, string> = {
  'taj-mahal': 'https://images.unsplash.com/photo-1564507592333-c60657eea523?w=600&q=80',
  'agra-fort': 'https://images.pexels.com/photos/3881104/pexels-photo-3881104.jpeg?w=600&q=80',
  'fatehpur-sikri': 'https://images.pexels.com/photos/1007426/pexels-photo-1007426.jpeg?w=600&q=80',
  'mehtab-bagh': 'https://images.unsplash.com/photo-1564507592333-c60657eea523?w=600&q=80',
  'red-fort': 'https://images.unsplash.com/photo-1587474260584-136574528ed5?w=600&q=80',
  'qutub-minar': 'https://images.unsplash.com/photo-1587474260584-136574528ed5?w=600&q=80',
  'india-gate': 'https://images.pexels.com/photos/1603650/pexels-photo-1603650.jpeg?w=600&q=80',
  'humayuns-tomb': 'https://images.unsplash.com/photo-1515091943-9d5c0ad475af?w=600&q=80',
  'amber-fort': 'https://images.unsplash.com/photo-1599661046289-e31897846e41?w=600&q=80',
  'hawa-mahal': 'https://images.unsplash.com/photo-1477587458883-47145ed94245?w=600&q=80',
  'city-palace': 'https://images.unsplash.com/photo-1603262110263-fb0112e7cc33?w=600&q=80',
  'jantar-mantar': 'https://images.unsplash.com/photo-1524492412937-b28074a5d7da?w=600&q=80',
};

// Hero-sized images for full-screen backgrounds
const heroImages: Record<string, string> = {
  'taj-mahal': 'https://images.unsplash.com/photo-1564507592333-c60657eea523?w=1920&q=80',
  'agra-fort': 'https://images.pexels.com/photos/3881104/pexels-photo-3881104.jpeg?w=1920&q=80',
  'fatehpur-sikri': 'https://images.pexels.com/photos/1007426/pexels-photo-1007426.jpeg?w=1920&q=80',
  'mehtab-bagh': 'https://images.unsplash.com/photo-1564507592333-c60657eea523?w=1920&q=80',
  'red-fort': 'https://images.unsplash.com/photo-1587474260584-136574528ed5?w=1920&q=80',
  'qutub-minar': 'https://images.unsplash.com/photo-1587474260584-136574528ed5?w=1920&q=80',
  'india-gate': 'https://images.pexels.com/photos/1603650/pexels-photo-1603650.jpeg?w=1920&q=80',
  'humayuns-tomb': 'https://images.unsplash.com/photo-1515091943-9d5c0ad475af?w=1920&q=80',
  'amber-fort': 'https://images.unsplash.com/photo-1599661046289-e31897846e41?w=1920&q=80',
  'hawa-mahal': 'https://images.unsplash.com/photo-1477587458883-47145ed94245?w=1920&q=80',
  'city-palace': 'https://images.unsplash.com/photo-1603262110263-fb0112e7cc33?w=1920&q=80',
  'jantar-mantar': 'https://images.unsplash.com/photo-1524492412937-b28074a5d7da?w=1920&q=80',
};

const tourImages: Record<string, string> = {
  'golden-triangle-3-days': 'https://images.unsplash.com/photo-1564507592333-c60657eea523?w=600&q=80',
  'golden-triangle-5-days': 'https://images.unsplash.com/photo-1599661046289-e31897846e41?w=600&q=80',
  'same-day-agra-from-delhi': 'https://images.unsplash.com/photo-1564507592333-c60657eea523?w=600&q=80',
  'agra-overnight-from-delhi': 'https://images.unsplash.com/photo-1564507592333-c60657eea523?w=600&q=80',
  'delhi-day-tour': 'https://images.unsplash.com/photo-1587474260584-136574528ed5?w=600&q=80',
  'jaipur-day-tour': 'https://images.unsplash.com/photo-1477587458883-47145ed94245?w=600&q=80',
};

const allAttractions = await getCollection('attractions');
const relatedAttractions = allAttractions
  .filter((a) => a.data.city === attraction.data.city && a.data.slug !== attraction.data.slug)
  .slice(0, 3);

const allTours = await getCollection('tours');
const relatedTours = allTours
  .filter((t) => t.data.cities.includes(attraction.data.city))
  .slice(0, 3);

const cityNames: Record<string, string> = { agra: 'Agra', delhi: 'Delhi', jaipur: 'Jaipur' };
const cityName = cityNames[attraction.data.city] || attraction.data.city;

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: cityName, href: `/${attraction.data.city}/` },
  { label: attraction.data.title },
];

const jsonLd = [
  buildTouristAttractionSchema({
    title: attraction.data.title,
    description: attraction.data.description,
    location: attraction.data.location,
    visitInfo: attraction.data.visitInfo,
    heroImage: attraction.data.heroImage,
    url: `${SITE_URL}/${attraction.data.city}/${attraction.data.slug}/`,
  }),
  buildFAQSchema(attraction.data.faqs),
  buildBreadcrumbSchema([
    { name: 'Home', url: SITE_URL },
    { name: cityName, url: `${SITE_URL}/${attraction.data.city}/` },
    { name: attraction.data.title, url: `${SITE_URL}/${attraction.data.city}/${attraction.data.slug}/` },
  ]),
];

const mapMarkers = [{
  lat: attraction.data.location.lat,
  lng: attraction.data.location.lng,
  title: attraction.data.title,
}];
---

<PageLayout
  title={`${attraction.data.metaTitle} — ${SITE_NAME}`}
  description={attraction.data.metaDescription}
  jsonLd={jsonLd}
  transparentHeader
>
  <HeroSection
    title={attraction.data.title}
    subtitle={attraction.data.description}
    backgroundImage={heroImages[attraction.data.slug] || attraction.data.heroImage}
    showStats={false}
  />

  <Section class="bg-white">
    <Container>
      <Breadcrumbs items={breadcrumbs} />

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 mt-8">
        <!-- Main Content -->
        <div class="lg:col-span-2 prose prose-lg prose-stone max-w-none">
          <Content />
        </div>

        <!-- Sidebar -->
        <aside class="space-y-6">
          <!-- Visit Info Card -->
          <div class="bg-white rounded-2xl shadow-lg p-6 sticky top-24">
            <h3 class="font-heading text-xl font-bold text-gray-900 mb-4">Visit Information</h3>
            <dl class="space-y-3 text-sm">
              <div class="flex justify-between">
                <dt class="text-gray-500">Entry Fee (Indian)</dt>
                <dd class="font-semibold text-gray-900">{attraction.data.visitInfo.entryFeeIndian}</dd>
              </div>
              <div class="flex justify-between">
                <dt class="text-gray-500">Entry Fee (Foreign)</dt>
                <dd class="font-semibold text-gray-900">{attraction.data.visitInfo.entryFeeForeign}</dd>
              </div>
              <div class="flex justify-between">
                <dt class="text-gray-500">Timings</dt>
                <dd class="font-semibold text-gray-900">{attraction.data.visitInfo.timings}</dd>
              </div>
              {attraction.data.visitInfo.closedOn && (
                <div class="flex justify-between">
                  <dt class="text-gray-500">Closed On</dt>
                  <dd class="font-semibold text-red-600">{attraction.data.visitInfo.closedOn}</dd>
                </div>
              )}
              <div class="flex justify-between">
                <dt class="text-gray-500">Best Time</dt>
                <dd class="font-semibold text-gray-900">{attraction.data.visitInfo.bestTimeToVisit}</dd>
              </div>
              <div class="flex justify-between">
                <dt class="text-gray-500">Duration</dt>
                <dd class="font-semibold text-gray-900">{attraction.data.visitInfo.duration}</dd>
              </div>
            </dl>
            <a href="/contact/" class="mt-6 block w-full text-center px-6 py-3 bg-amber-600 text-white rounded-lg font-semibold hover:bg-amber-700 transition-colors">
              Book Guided Tour
            </a>
          </div>

          <!-- Tips -->
          {attraction.data.tips.length > 0 && (
            <div class="bg-amber-50 rounded-2xl p-6">
              <h3 class="font-heading text-lg font-bold text-gray-900 mb-3">Insider Tips</h3>
              <ul class="space-y-2 text-sm text-gray-700">
                {attraction.data.tips.map((tip: string) => (
                  <li class="flex gap-2">
                    <span class="text-amber-600 mt-1 shrink-0">&#10003;</span>
                    <span>{tip}</span>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </aside>
      </div>
    </Container>
  </Section>

  <!-- Photo Gallery -->
  {attraction.data.gallery.length > 0 && (
    <Section class="bg-stone-50">
      <Container>
        <h2 class="font-heading text-3xl font-bold text-gray-900 mb-8 text-center">
          Photo Gallery
        </h2>
        <PhotoGallery images={attraction.data.gallery} client:visible />
      </Container>
    </Section>
  )}

  <!-- Map -->
  <Section class="bg-white">
    <Container>
      <h2 class="font-heading text-2xl font-bold text-gray-900 mb-6">Location</h2>
      <p class="text-gray-600 mb-4">{attraction.data.location.address}</p>
      <div class="rounded-2xl overflow-hidden shadow-lg h-[300px]">
        <InteractiveMap
          markers={mapMarkers}
          center={{ lat: attraction.data.location.lat, lng: attraction.data.location.lng }}
          zoom={15}
          client:only="react"
        />
      </div>
    </Container>
  </Section>

  <!-- Related Attractions -->
  {relatedAttractions.length > 0 && (
    <Section class="bg-stone-50">
      <Container>
        <h2 class="font-heading text-3xl font-bold text-gray-900 mb-8 text-center">
          More Attractions in {cityName}
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
          {relatedAttractions.map((a) => (
            <AttractionCard
              title={a.data.title}
              slug={a.data.slug}
              city={a.data.city}
              image={attractionImages[a.data.slug] || a.data.heroImage}
              description={a.data.description}
              duration={a.data.visitInfo.duration}
            />
          ))}
        </div>
      </Container>
    </Section>
  )}

  <!-- Related Tours -->
  {relatedTours.length > 0 && (
    <Section class="bg-white">
      <Container>
        <h2 class="font-heading text-3xl font-bold text-gray-900 mb-8 text-center">
          Tours Including {attraction.data.title}
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {relatedTours.map((tour) => (
            <TourCard
              title={tour.data.title}
              slug={tour.data.slug}
              image={tourImages[tour.data.slug] || tour.data.heroImage}
              duration={tour.data.duration}
              price={tour.data.priceFrom}
              highlights={tour.data.highlights.slice(0, 3)}
            />
          ))}
        </div>
      </Container>
    </Section>
  )}

  <!-- FAQs -->
  {attraction.data.faqs.length > 0 && (
    <Section class="bg-stone-50" id="faqs">
      <Container>
        <h2 class="font-heading text-3xl font-bold text-gray-900 mb-8 text-center">
          Frequently Asked Questions
        </h2>
        <div class="max-w-3xl mx-auto">
          <FAQAccordion items={attraction.data.faqs} client:visible />
        </div>
      </Container>
    </Section>
  )}

  <CTABanner
    title={`Want a Guided Tour of ${attraction.data.title}?`}
    subtitle="Our licensed guides bring history to life with stories and insights you won't find in any guidebook."
    ctaText="Book Your Guide"
    ctaHref="/contact/"
  />
</PageLayout>
