---
import PageLayout from '../layouts/PageLayout.astro';
import Container from '../components/ui/Container.astro';
import Section from '../components/ui/Section.astro';
import Breadcrumbs from '../components/layout/Breadcrumbs.astro';
import CTABanner from '../components/sections/CTABanner.astro';
import {
  buildOrganizationSchema,
  buildBreadcrumbSchema,
  buildReviewsCollectionSchema,
  buildFAQSchema,
} from '../lib/schema';
import {
  SITE_NAME,
  SITE_URL,
  REVIEW_RATING,
  REVIEW_COUNT,
  GOOGLE_REVIEWS_URL,
} from '../lib/constants';
import { REAL_REVIEWS } from '../lib/reviews';

const pageUrl = `${SITE_URL}/reviews/`;

const reviewFaqs = [
  {
    question: `Are the ${REVIEW_COUNT} reviews on this page real?`,
    answer: `Yes — every review on this page is copied verbatim from our verified Google Business profile, which any traveller can independently confirm. We do not write, edit, or filter reviews. Our overall rating is ${REVIEW_RATING.toFixed(1)} stars across ${REVIEW_COUNT} reviewers, and you can read the unedited originals on Google Maps.`,
  },
  {
    question: 'How do you have a 5.0 rating with 81 reviews?',
    answer: `We do small-group, owner-led tours and personally manage every booking — no aggregator, no upsell, no commission shop visits unless requested. With that model, an unhappy traveller is rare. Of ${REVIEW_COUNT} Google reviews, 100% are 5-star, with travellers from 30+ countries.`,
  },
  {
    question: 'Can I leave a review after my tour?',
    answer: 'Yes — please do. After every tour we share a Google Reviews link so you can post a public review in under a minute. Honest feedback (good or bad) is the only way small Agra businesses like ours stay visible against big aggregators. We read every word.',
  },
];

const jsonLd = [
  buildOrganizationSchema(),
  buildBreadcrumbSchema([
    { name: 'Home', url: SITE_URL },
    { name: 'Reviews', url: pageUrl },
  ]),
  ...buildReviewsCollectionSchema(REAL_REVIEWS),
  buildFAQSchema(reviewFaqs),
];

const flagMap: Record<string, string> = {
  "Czech Republic": "\u{1F1E8}\u{1F1FF}", Germany: "\u{1F1E9}\u{1F1EA}", Australia: "\u{1F1E6}\u{1F1FA}",
  India: "\u{1F1EE}\u{1F1F3}", Italy: "\u{1F1EE}\u{1F1F9}", "United Kingdom": "\u{1F1EC}\u{1F1E7}",
  "United States": "\u{1F1FA}\u{1F1F8}", France: "\u{1F1EB}\u{1F1F7}", Spain: "\u{1F1EA}\u{1F1F8}",
  Netherlands: "\u{1F1F3}\u{1F1F1}", Japan: "\u{1F1EF}\u{1F1F5}", Canada: "\u{1F1E8}\u{1F1E6}",
  Belgium: "\u{1F1E7}\u{1F1EA}", Singapore: "\u{1F1F8}\u{1F1EC}", Mauritius: "\u{1F1F2}\u{1F1FA}",
  Malaysia: "\u{1F1F2}\u{1F1FE}", Egypt: "\u{1F1EA}\u{1F1EC}", Oman: "\u{1F1F4}\u{1F1F2}",
  "United Arab Emirates": "\u{1F1E6}\u{1F1EA}", Kenya: "\u{1F1F0}\u{1F1EA}",
  "South Africa": "\u{1F1FF}\u{1F1E6}", Iran: "\u{1F1EE}\u{1F1F7}", Ireland: "\u{1F1EE}\u{1F1EA}",
};

const colors = ["bg-amber-500", "bg-emerald-600", "bg-rose-500", "bg-indigo-500", "bg-orange-500", "bg-teal-600", "bg-purple-500", "bg-pink-500"];

function initials(name: string) {
  return name.split(" ").filter(Boolean).slice(0, 2).map((n) => n[0]).join("").toUpperCase();
}

const lastUpdated = "April 2026";

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Reviews' },
];
---

<PageLayout
  title={`Reviews — ${REVIEW_RATING.toFixed(1)}★ from ${REVIEW_COUNT} Travellers | ${SITE_NAME}`}
  description={`Read all ${REVIEW_COUNT} verified Google reviews for Agra Tour Guides. ${REVIEW_RATING.toFixed(1)}-star private Taj Mahal & Golden Triangle tours, real travellers from 30+ countries.`}
  jsonLd={jsonLd}
  canonical={pageUrl}
>
  <Section class="bg-gradient-to-b from-amber-50 to-white">
    <Container>
      <Breadcrumbs items={breadcrumbs} />

      <header class="text-center max-w-3xl mx-auto mb-12 mt-6">
        <p class="text-sm font-semibold uppercase tracking-widest text-amber-600 mb-3">Verified Google Reviews</p>
        <h1 class="font-heading text-4xl md:text-5xl font-bold text-gray-900 mb-4">
          {REVIEW_RATING.toFixed(1)}★ from {REVIEW_COUNT} Travellers
        </h1>
        <p class="text-lg text-gray-700 leading-relaxed">
          Every review on this page is copied directly from our Google Business profile — no edits, no filters. Travellers from 30+ countries have rated us across {new Date().getFullYear() - 2022}+ years of guiding the Taj Mahal, Agra Fort and the Golden Triangle.
        </p>
        <p class="mt-3 text-xs text-gray-500">Last updated {lastUpdated} · Sorted newest first</p>
      </header>

      <!-- Trust banner -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-3xl mx-auto mb-16 bg-white border border-amber-100 rounded-2xl p-6 shadow-sm">
        <div class="text-center">
          <p class="font-heading text-3xl font-bold text-amber-600">{REVIEW_RATING.toFixed(1)}★</p>
          <p class="text-xs text-gray-600 mt-1">Average rating</p>
        </div>
        <div class="text-center">
          <p class="font-heading text-3xl font-bold text-amber-600">{REVIEW_COUNT}</p>
          <p class="text-xs text-gray-600 mt-1">Verified reviews</p>
        </div>
        <div class="text-center">
          <p class="font-heading text-3xl font-bold text-amber-600">100%</p>
          <p class="text-xs text-gray-600 mt-1">5-star reviews</p>
        </div>
        <div class="text-center">
          <p class="font-heading text-3xl font-bold text-amber-600">30+</p>
          <p class="text-xs text-gray-600 mt-1">Countries</p>
        </div>
      </div>
    </Container>
  </Section>

  <Section class="bg-white">
    <Container>
      <!-- Reviews grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {REAL_REVIEWS.map((r, i) => (
          <article class="bg-white border border-gray-100 rounded-2xl p-6 shadow-sm hover:shadow-md transition-shadow">
            <div class="flex items-start justify-between mb-4">
              <div class="flex items-center gap-3">
                <div class={`flex h-10 w-10 items-center justify-center rounded-full text-xs font-bold text-white ${colors[i % colors.length]}`}>
                  {initials(r.author)}
                </div>
                <div>
                  <p class="text-sm font-bold text-gray-900">{r.author}</p>
                  <p class="text-xs text-gray-600">{r.country ? `${flagMap[r.country] ?? ""} ${r.country}` : ""} · {new Date(r.datePublished).toLocaleString("en", { month: "short", year: "numeric" })}</p>
                </div>
              </div>
              <svg class="h-5 w-5 text-gray-400" viewBox="0 0 24 24" fill="currentColor" aria-label="Google">
                <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
                <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
              </svg>
            </div>
            <div class="flex gap-0.5 mb-3">
              {Array.from({ length: r.rating }).map(() => (
                <svg class="h-4 w-4 text-amber-400" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <p class="text-sm text-gray-800 leading-relaxed">{r.text}</p>
          </article>
        ))}
      </div>

      <!-- Note about additional reviews -->
      {REAL_REVIEWS.length < REVIEW_COUNT && (
        <p class="text-center text-sm text-gray-600 mt-12 max-w-2xl mx-auto">
          Showing {REAL_REVIEWS.length} of {REVIEW_COUNT} reviews. The full list — including reviews left in languages other than English — is available on our <a href={GOOGLE_REVIEWS_URL} target="_blank" rel="noopener noreferrer" class="text-amber-700 underline hover:no-underline">Google Business profile</a>.
        </p>
      )}

      <!-- FAQ for AEO -->
      <div class="max-w-3xl mx-auto mt-20">
        <h2 class="font-heading text-2xl font-bold text-gray-900 mb-8 text-center">Questions about our reviews</h2>
        <div class="space-y-6">
          {reviewFaqs.map((f) => (
            <details class="group bg-amber-50 rounded-xl p-5 border border-amber-100">
              <summary class="font-semibold text-gray-900 cursor-pointer flex items-center justify-between gap-4">
                {f.question}
                <svg class="h-5 w-5 text-amber-600 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                </svg>
              </summary>
              <p class="text-sm text-gray-700 mt-3 leading-relaxed">{f.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </Container>
  </Section>

  <CTABanner
    title="Want to be our next review?"
    subtitle="WhatsApp us your dates, group size and language. You'll get a quote in under 2 hours, and pay only on the day of the tour."
    ctaText="WhatsApp Us Now"
    ctaLink="/contact/"
  />
</PageLayout>
