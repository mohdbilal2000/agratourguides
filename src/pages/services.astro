---
import PageLayout from '../layouts/PageLayout.astro';
import Container from '../components/ui/Container.astro';
import Section from '../components/ui/Section.astro';
import Breadcrumbs from '../components/layout/Breadcrumbs.astro';
import CTABanner from '../components/sections/CTABanner.astro';
import {
  buildOrganizationSchema,
  buildBreadcrumbSchema,
  buildFAQSchema,
} from '../lib/schema';
import { SITE_NAME, SITE_URL, WHATSAPP_NUMBER_DIGITS } from '../lib/constants';

const pageUrl = `${SITE_URL}/services/`;

const tiers = [
  {
    name: "Guide Only",
    bestFor: "Independent travellers who already have a hotel & cab",
    fromUSD: 22,
    fromEUR: 20,
    fromINR: 1800,
    inrUnit: "for group up to 5 (1.5–2 hr)",
    includes: [
      "Government-licensed Agra guide",
      "Inside-monument guiding (Taj Mahal, Agra Fort, etc.)",
      "Skip-the-line entry coordination",
      "Photo spots + travel-style photos on your phone",
      "Local restaurant + shop recommendations",
    ],
    excludes: [
      "Monument entry tickets (paid at gate)",
      "Transport to/from your hotel",
    ],
    cta: "Book Guide Only",
    whatsappText: "Hi! I want to book a Guide-Only tour. My dates: ___, group size: ___.",
  },
  {
    name: "Guide + Cab",
    bestFor: "Most travellers — same-day Agra from Delhi or Agra-only trips",
    fromUSD: 89,
    fromEUR: 82,
    fromINR: 7500,
    inrUnit: "per person, group of 2",
    popular: true,
    includes: [
      "Everything in Guide Only",
      "Private AC sedan or SUV (Toyota Innova / Etios)",
      "Background-verified, English-speaking driver",
      "Hotel pickup + drop-off (Agra) or door-to-door (Delhi same-day)",
      "Bottled water + WiFi in vehicle",
      "All toll, parking, fuel covered",
    ],
    excludes: [
      "Monument entry tickets (paid at gate or pre-booked online)",
      "Lunch (we recommend, you pay direct)",
    ],
    cta: "Book Guide + Cab",
    whatsappText: "Hi! I want to book a Guide + Cab tour. My dates: ___, pickup city: ___, group size: ___.",
  },
  {
    name: "All-Inclusive Golden Triangle",
    bestFor: "First-time visitors doing Delhi → Agra → Jaipur",
    fromUSD: 299,
    fromEUR: 274,
    fromINR: 25000,
    inrUnit: "per person, 3 days, double occupancy",
    includes: [
      "Everything in Guide + Cab, across all 3 cities",
      "3-star or 4-star hotel accommodation (your choice)",
      "All monument entry tickets pre-booked",
      "Multiple licensed guides (one per city, all govt-certified)",
      "Daily breakfast, hotel-direct check-in",
      "24/7 WhatsApp support during the trip",
    ],
    excludes: [
      "International flights",
      "Indian visa (you arrange)",
      "Lunch & dinner (we recommend places that fit your budget)",
    ],
    cta: "Plan Golden Triangle",
    whatsappText: "Hi! I want to plan a Golden Triangle trip. My dates: ___, group size: ___, hotel preference: ___.",
  },
  {
    name: "Custom Itinerary",
    bestFor: "Honeymoons, families, photographers, multi-week India trips",
    fromUSD: null,
    fromEUR: null,
    fromINR: null,
    inrUnit: "Quote within 24 hours",
    includes: [
      "Bespoke route — Rajasthan, Varanasi, Khajuraho, Himalayas",
      "Heritage hotel & palace-stay options",
      "Private photographer add-on",
      "Cooking classes, marble inlay workshops, dawn yoga",
      "Domestic flights & trains booked on your behalf",
      "Single point of contact, end-to-end",
    ],
    excludes: [
      "Whatever you don't want — fully flexible",
    ],
    cta: "Plan Custom Trip",
    whatsappText: "Hi! I want a custom India itinerary. Travel dates: ___, must-see places: ___, budget per person: ___.",
  },
];

const modules = [
  { icon: "car", title: "Private AC Transport", desc: "Sedans, SUVs, and Tempo Travellers (8–14 seats). Verified drivers." },
  { icon: "camera", title: "Photo Tour Add-On", desc: "Travel-magazine angles at the Taj. Phone photos free; pro DSLR shoots on request." },
  { icon: "phone", title: "24/7 WhatsApp Support", desc: "Stuck at midnight? Text us. We've got your back from the moment you land." },
  { icon: "fork", title: "Food & Cooking", desc: "Curated street-food walks (Agra petha, Delhi chaat) and home-cooked meals." },
  { icon: "shield", title: "Skip-the-Line Tickets", desc: "Pre-booked Taj Mahal e-tickets — no queue, no scams, no extras." },
  { icon: "translate", title: "Multilingual Guides", desc: "English, Hindi, Japanese in-house. French, Spanish, German on coordination." },
  { icon: "hotel", title: "Hotel Sourcing", desc: "From budget heritage to Oberoi Amarvilas — booked at our partner rates." },
  { icon: "calendar", title: "Flexible Pacing", desc: "Sunrise tour, late afternoon, or two-day relaxed pace — your call." },
  { icon: "ticket", title: "Tickets & Permits", desc: "Mausoleum mainroom (₹200), Mehtab Bagh, Fatehpur Sikri — all sorted." },
];

const servicesFaqs = [
  {
    question: 'Which service tier should I pick if I\'ve never been to India?',
    answer: 'Most first-time travellers from the US/UK/EU pick Guide + Cab for a same-day or 1-night Agra trip from Delhi. If you have 3+ days, the All-Inclusive Golden Triangle removes every logistical headache: hotels, transport, tickets, and licensed guides in all three cities. WhatsApp us your dates and we\'ll recommend honestly.',
  },
  {
    question: 'Do you take commission from shops if I visit during the tour?',
    answer: 'No. We are a flat-fee service — your guide is paid the same whether or not you buy anything. We will show you marble-inlay workshops and carpet factories on request because reviewers love them, but there is zero pressure and no commission percentage hidden in the price.',
  },
  {
    question: 'Can I pay in USD, EUR, or only Indian rupees?',
    answer: 'Cash in USD, EUR, GBP, AUD or INR all accepted at the same fair exchange rate (we use Google\'s mid-market rate). UPI/Indian bank transfer if you\'re already in India. Wise/Revolut payments to our INR account work for advances. Card payments via PayPal on request — note PayPal adds 4.4%.',
  },
  {
    question: 'How far in advance should I book?',
    answer: 'For October-March (peak season), 1-2 weeks lead time is comfortable. Sunrise tours in December often book out 5-7 days ahead. For April-September (low season), 48 hours is enough. Last-minute? WhatsApp us anyway — same-day bookings happen, especially mid-week.',
  },
  {
    question: 'What if I need to cancel or my flight is delayed?',
    answer: 'Free cancellation up to 24 hours before the tour, full refund of any advance. Flight delays are common — message us when you know, and we\'ll reschedule the same trip at no charge. We don\'t charge no-show fees for genuine emergencies; we want lifetime travellers, not single transactions.',
  },
];

const jsonLd = [
  buildOrganizationSchema(),
  buildBreadcrumbSchema([
    { name: 'Home', url: SITE_URL },
    { name: 'Services', url: pageUrl },
  ]),
  buildFAQSchema(servicesFaqs),
];

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Services' },
];

const lastUpdated = "April 2026";
---

<PageLayout
  title={`Tour Services & Pricing — ${SITE_NAME} | Taj Mahal & Golden Triangle`}
  description={`Four flexible service tiers from a 5.0★ Agra agency. Guide-only from $22, Guide+Cab from $89, Golden Triangle all-inclusive from $299. Transparent USD/EUR/INR pricing.`}
  jsonLd={jsonLd}
>
  <Section class="bg-gradient-to-b from-amber-50 to-white">
    <Container>
      <Breadcrumbs items={breadcrumbs} />
      <header class="text-center max-w-3xl mx-auto mb-12 mt-6">
        <p class="text-sm font-semibold uppercase tracking-widest text-amber-600 mb-3">Services & Pricing</p>
        <h1 class="font-heading text-4xl md:text-5xl font-bold text-gray-900 mb-4">
          Pick the tier that fits your trip
        </h1>
        <p class="text-lg text-gray-700 leading-relaxed">
          We publish pricing up-front in USD, EUR and INR — no quote-haggling, no hidden surcharges. All prices below include the licensed guide and exclude only what your government already collects (monument tickets) and meals you choose.
        </p>
        <p class="mt-3 text-xs text-gray-500">Updated {lastUpdated} · Prices may vary on national holidays</p>
      </header>
    </Container>
  </Section>

  <Section class="bg-white">
    <Container>
      <!-- 4 service tiers -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8">
        {tiers.map((t) => (
          <article class={`relative rounded-2xl p-8 border-2 ${t.popular ? "border-amber-500 bg-amber-50/40" : "border-gray-200 bg-white"} flex flex-col`}>
            {t.popular && (
              <span class="absolute -top-3 left-8 px-3 py-1 rounded-full bg-amber-500 text-white text-xs font-bold uppercase tracking-wider">Most Popular</span>
            )}
            <h2 class="font-heading text-2xl font-bold text-gray-900">{t.name}</h2>
            <p class="text-sm text-gray-700 mt-2 mb-6">{t.bestFor}</p>

            <div class="mb-6">
              {t.fromUSD !== null ? (
                <>
                  <p class="text-xs uppercase tracking-wide text-gray-500">From</p>
                  <p class="font-heading text-3xl font-bold text-gray-900">${t.fromUSD} <span class="text-sm font-normal text-gray-600">/ €{t.fromEUR} / ₹{t.fromINR}</span></p>
                  <p class="text-xs text-gray-600 mt-1">{t.inrUnit}</p>
                </>
              ) : (
                <>
                  <p class="font-heading text-2xl font-bold text-gray-900">Custom quote</p>
                  <p class="text-xs text-gray-600 mt-1">{t.inrUnit}</p>
                </>
              )}
            </div>

            <div class="space-y-1 mb-6 flex-1">
              <p class="text-xs uppercase tracking-wide text-gray-500 mb-2">Included</p>
              <ul class="space-y-1.5">
                {t.includes.map((item) => (
                  <li class="flex items-start gap-2 text-sm text-gray-800">
                    <svg class="h-4 w-4 text-emerald-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                    {item}
                  </li>
                ))}
              </ul>
              <p class="text-xs uppercase tracking-wide text-gray-500 mt-4 mb-2">Not included</p>
              <ul class="space-y-1.5">
                {t.excludes.map((item) => (
                  <li class="flex items-start gap-2 text-sm text-gray-700">
                    <svg class="h-4 w-4 text-gray-400 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
                    {item}
                  </li>
                ))}
              </ul>
            </div>

            <a
              href={`https://wa.me/${WHATSAPP_NUMBER_DIGITS}?text=${encodeURIComponent(t.whatsappText)}`}
              target="_blank"
              rel="noopener noreferrer"
              class={`block w-full text-center px-6 py-3 rounded-lg font-semibold transition-colors ${t.popular ? "bg-amber-500 text-white hover:bg-amber-600" : "bg-gray-900 text-white hover:bg-gray-800"}`}
            >
              {t.cta} on WhatsApp
            </a>
          </article>
        ))}
      </div>
    </Container>
  </Section>

  <!-- 9 service modules -->
  <Section class="bg-stone-50">
    <Container>
      <div class="text-center mb-12">
        <p class="text-sm font-semibold uppercase tracking-widest text-amber-600 mb-3">Complete Suite</p>
        <h2 class="font-heading text-3xl md:text-4xl font-bold text-gray-900">Add-ons available with any tier</h2>
        <p class="mt-3 text-gray-700 max-w-2xl mx-auto">Mix and match. Tell us what you need on WhatsApp and we'll build it into your itinerary.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {modules.map((m) => (
          <div class="bg-white rounded-2xl p-6 border border-stone-100 hover:shadow-md transition-shadow">
            <div class="flex h-11 w-11 items-center justify-center rounded-full bg-amber-100 border border-amber-200 mb-4">
              <svg class="h-5 w-5 text-amber-700" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                {m.icon === "car" && <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9-3.75V6a2.25 2.25 0 012.25-2.25h11.25c.621 0 1.125.504 1.125 1.125v6.75M9.75 9h7.5" />}
                {m.icon === "camera" && <path stroke-linecap="round" stroke-linejoin="round" d="M6.827 6.175A2.31 2.31 0 015.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574v9.176A2.25 2.25 0 004.5 21h15a2.25 2.25 0 002.25-2.25V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 00-1.134-.175 2.31 2.31 0 01-1.64-1.055l-.822-1.316a2.192 2.192 0 00-1.736-1.039 48.774 48.774 0 00-5.232 0 2.192 2.192 0 00-1.736 1.039l-.821 1.316z M16.5 12.75a4.5 4.5 0 11-9 0 4.5 4.5 0 019 0z" />}
                {m.icon === "phone" && <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />}
                {m.icon === "fork" && <path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9 5.25h.008v.008H12v-.008z" />}
                {m.icon === "shield" && <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z" />}
                {m.icon === "translate" && <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 21l5.25-11.25L21 21m-9-3h7.5M3 5.621a48.474 48.474 0 016-.371m0 0c1.12 0 2.233.038 3.334.114M9 5.25V3m3.334 2.364C11.176 10.658 7.69 15.08 3 17.502m9.334-12.138c.896.061 1.785.147 2.666.257m-4.589 8.495a18.023 18.023 0 01-3.827-5.802" />}
                {m.icon === "hotel" && <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21" />}
                {m.icon === "calendar" && <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />}
                {m.icon === "ticket" && <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 6v.75m0 3v.75m0 3v.75m0 3V18m-9-5.25h5.25M7.5 15h3M3.375 5.25c-.621 0-1.125.504-1.125 1.125v3.026a2.999 2.999 0 010 5.198v3.026c0 .621.504 1.125 1.125 1.125h17.25c.621 0 1.125-.504 1.125-1.125v-3.026a2.999 2.999 0 010-5.198V6.375c0-.621-.504-1.125-1.125-1.125H3.375z" />}
              </svg>
            </div>
            <h3 class="font-bold text-gray-900 text-lg mb-1">{m.title}</h3>
            <p class="text-sm text-gray-700 leading-relaxed">{m.desc}</p>
          </div>
        ))}
      </div>
    </Container>
  </Section>

  <!-- FAQ -->
  <Section class="bg-white">
    <Container>
      <div class="max-w-3xl mx-auto">
        <h2 class="font-heading text-3xl md:text-4xl font-bold text-gray-900 mb-8 text-center">Frequently asked questions</h2>
        <div class="space-y-4">
          {servicesFaqs.map((f) => (
            <details class="group bg-amber-50 rounded-xl p-5 border border-amber-100">
              <summary class="font-semibold text-gray-900 cursor-pointer flex items-center justify-between gap-4">
                {f.question}
                <svg class="h-5 w-5 text-amber-600 group-open:rotate-180 transition-transform shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
              </summary>
              <p class="text-sm text-gray-700 mt-3 leading-relaxed">{f.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </Container>
  </Section>

  <CTABanner
    title="Not sure which tier?"
    subtitle="Tell us your travel dates, group size, and what you want to see. We'll suggest honestly — even if that means a smaller package."
    ctaText="WhatsApp Us"
    ctaLink="/contact/"
  />
</PageLayout>
